# Apple Music developer token inputs.
# APPLE_PRIVATE_KEY may be a path to AuthKey_XXXXXXXXXX.p8 or the raw PEM text.
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=YYYYYYYYYY
APPLE_PRIVATE_KEY=/absolute/path/to/AuthKey_YYYYYYYYYY.p8

# ytmusicapi browser auth file created once with:
# ytmusicapi browser
YTMUSIC_AUTH_FILE=/absolute/path/to/browser.json

# Existing YouTube Music playlist to overwrite each day.
# Usually the value after "list=" in a YouTube Music playlist URL.
YTMUSIC_KR_TOP100_PLAYLIST_ID=PLxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
YTMUSIC_PLAYLIST_ID=PLxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides.
APPLE_STOREFRONT=kr
APPLE_PLAYLIST_ID=pl.d3d10c32fbc540b38e266367dc8cb00c
APPLE_PLAYLIST_URL=https://music.apple.com/kr/new/top-charts/songs
APPLE_CHART_LIMIT=200
SPOTIFY_PLAYLIST_URL=https://open.spotify.com/playlist/37i9dQZF1DWT9uTRZAYj0c
SPOTIFY_TRACK_LIMIT=
USE_MUSICBRAINZ=true
MUSICBRAINZ_USER_AGENT=app_to_you/1.0 (https://github.com/yule/app_to_you)
